# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Paths to your local Google service-account JSON key files
GOOGLE_DRIVE_CREDENTIALS_FILE=C:\path\to\drive-credentials.json
GOOGLE_SHEETS_CREDENTIALS_FILE=C:\path\to\sheets-credentials.json

# Google Drive folder ID that contains the Bluecoins .fydb and the spreadsheet
# Leave blank to search your entire Drive
DRIVE_FOLDER_ID=

# Bluecoins Quick Sync folder ID (leave blank to skip)
QUICK_SYNC_FOLDER_ID=

# Exact name of the Google Sheet
SHEET_TITLE=finances

# Bluecoins internal account ID for the Gold account
GOLD_ACCOUNT_ID=
